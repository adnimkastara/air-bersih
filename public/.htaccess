<IfModule mod_rewrite.c>
    RewriteEngine On

    # If hosting cannot point DocumentRoot to /public,
    # this file (placed in /public_html/airbersih) forwards all requests to /public.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>